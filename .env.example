# --- required ---
DEEPGRAM_API_KEY=dg_your_key
# the shared secret from your StandIn identity (pairing issues it); must match exactly
WORKER_SHARED_SECRET=change-me

# --- the agent (no dashboard: the bridge configures each Voice Agent session itself) ---
# STT model for agent.listen
DEEPGRAM_LISTEN_MODEL=nova-3
# LLM for agent.think (Deepgram-managed provider + model)
DEEPGRAM_THINK_PROVIDER=open_ai
DEEPGRAM_THINK_MODEL=gpt-4o-mini
# Aura TTS voice for agent.speak
DEEPGRAM_SPEAK_MODEL=aura-2-thalia-en
DEEPGRAM_LANGUAGE=en
# base system prompt (per-call caller context is appended automatically)
#DEEPGRAM_PROMPT=You are Komaa's friendly receptionist. Keep replies short; you are speaking aloud on a phone call.
# deterministic opening line / spoken AI disclosure (Settings agent.greeting)
#DEEPGRAM_GREETING=Hello! You've reached Komaa. How can I help?
# BYO LLM: REQUIRED for third-party think providers (google, groq, aws_bedrock, ...);
# Deepgram-managed open_ai/anthropic work without it. Deepgram dials this URL itself.
#DEEPGRAM_THINK_ENDPOINT_URL=https://your-llm.example.com/v1/chat/completions
#DEEPGRAM_THINK_ENDPOINT_HEADERS={"authorization":"Bearer ..."}

# --- optional ---
PORT=8080
BIND=0.0.0.0

# TLS: with BOTH set the bridge serves wss:// itself. Without them it is plain WS
# and MUST be fronted by a TLS terminator (tunnel / ingress / LB).
#TLS_CERT_PATH=/path/to/fullchain.pem
#TLS_KEY_PATH=/path/to/privkey.pem

# Deepgram hosts (restricted to *.deepgram.com so the API key can't be sent elsewhere;
# DEEPGRAM_HOST_ALLOW_ANY=true only for a deliberate trusted proxy/test host).
# Regional pins: api.eu.deepgram.com / api.au.deepgram.com (set BOTH hosts).
#DEEPGRAM_AGENT_HOST=agent.deepgram.com
#DEEPGRAM_API_HOST=api.deepgram.com

# enables the deterministic governor goodbye via the standalone Aura TTS endpoint;
# without it the goodbye is spoken verbatim by the live agent (InjectAgentMessage)
#DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# bridge-side call governor: hard cap in minutes (fractional ok); 0 = disabled
MAX_CALL_MINUTES=0
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
# grace before session.end when the goodbye duration is unknown (agent-spoken fallback)
GOODBYE_GRACE_MS=8000

# vision (the look tool): any OpenAI-compatible chat-completions endpoint with image
# input. The Voice Agent API is audio-only, so this is the ONLY vision route - the raw
# frame is sent to THIS endpoint (never to Deepgram); run a local model if frames must
# not leave your infrastructure.
#VISION_API_URL=https://api.openai.com/v1/chat/completions
#VISION_API_KEY=
#VISION_MODEL=gpt-4o-mini
# compliance gate: refuse to process caller video unless Teams recording is active
#VISION_REQUIRES_RECORDING=true

# HMAC replay window in ms (worker documents +-60s)
HMAC_FRESHNESS_MS=60000
# DoS guards (0 = built-in defaults: 64 / =total / 10000 / 90000)
MAX_CONNECTIONS=0
MAX_CONNECTIONS_PER_IP=0
PRE_START_TIMEOUT_MS=0
WORKER_IDLE_TIMEOUT_MS=0
# log transcripts (ConversationText; still gated on Teams recording.status == "active")
LOG_TRANSCRIPTS=false
LOG_LEVEL=info
